# =============================================================================
# OSSAF Local Development Environment - .env.mock
# =============================================================================
# ✅ 仅本地开发使用，可公开提交
# 本文件包含Mock服务的公开凭证，用于本地开发和CI环境
# 所有SK-MOCK-*密钥为公开测试凭证，不提供任何真实API访问能力
# =============================================================================

# ---------- OSSAF 核心配置 ----------
OSSAF_API_BASE_URL=http://127.0.0.1:8765
OSSAF_AI_BACKEND=mock

# ---------- Mock API 密钥（公开测试凭证，可安全提交） ----------
ANTHROPIC_API_KEY=SK-MOCK-ANTHROPIC-DEV-001
OPENAI_API_KEY=SK-MOCK-OPENAI-DEV-001
GOOGLE_API_KEY=SK-MOCK-GOOGLE-DEV-001
GITHUB_TOKEN=SK-MOCK-GITHUB-DEV-001
ALTERNATIVETO_API_KEY=SK-MOCK-ALTERNATIVETO-DEV-001

# ---------- Hugo 配置 ----------
HUGO_ENVIRONMENT=development

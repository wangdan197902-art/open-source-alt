# =============================================================================
# OSSAF Local Development Environment - .env.example
# =============================================================================
# ⚠️ 本文件仅作模板，禁止填入真实密钥
# 本文件可被git追踪，作为团队共享的配置占位符模板
# 真实密钥请填写至 .env.local（已被gitignore）
# =============================================================================

# ---------- OSSAF 核心配置 ----------
OSSAF_API_BASE_URL=http://127.0.0.1:8765
OSSAF_AI_BACKEND=mock

# ---------- API 密钥（占位符，禁止填入真实值） ----------
ANTHROPIC_API_KEY=SK-PLACEHOLDER-DO-NOT-USE
OPENAI_API_KEY=SK-PLACEHOLDER-DO-NOT-USE
GOOGLE_API_KEY=SK-PLACEHOLDER-DO-NOT-USE
GITHUB_TOKEN=SK-PLACEHOLDER-DO-NOT-USE
ALTERNATIVETO_API_KEY=SK-PLACEHOLDER-DO-NOT-USE

# ---------- AGNES_LLM 配置（国内可达） ----------
AGNES_API_KEY=SK-MOCK-AGNES-DEV-001
OSSAF_AI_PROVIDER=mock  # 可选: mock/claude/openai/gemini/agnes

# ---------- Hugo 配置 ----------
HUGO_ENVIRONMENT=development

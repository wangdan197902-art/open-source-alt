{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ossaf.local/schemas/proprietary.schema.json",
  "title": "Proprietary Software",
  "description": "商业软件记录的单一真相源 (SSOT)，供 Mock 数据生成器、Hugo 内容生成器和适配器共用。",
  "type": "object",
  "required": [
    "id",
    "name",
    "vendor",
    "category",
    "officialUrl",
    "pricingModel",
    "platforms",
    "trademarkStatus",
    "reviewStatus",
    "aiGenerated",
    "_meta"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，使用 kebab-case，如 'photoshop'、'microsoft-office'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "description": "软件官方名称，如 'Adobe Photoshop'",
      "minLength": 1,
      "maxLength": 128
    },
    "vendor": {
      "type": "string",
      "description": "软件厂商/提供商名称，如 'Adobe'、'Microsoft'",
      "minLength": 1,
      "maxLength": 128
    },
    "category": {
      "type": "string",
      "description": "分类标识符，使用 kebab-case，如 'image-editing'、'office-suite'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "officialUrl": {
      "type": "string",
      "description": "软件官方网站URL",
      "format": "uri",
      "pattern": "^https?://"
    },
    "pricingModel": {
      "type": "string",
      "description": "定价模型，如 'subscription'、'one-time'、'freemium'",
      "minLength": 1,
      "maxLength": 64
    },
    "platforms": {
      "type": "array",
      "description": "支持的平台列表，如 ['windows', 'macos', 'linux']",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "trademarkStatus": {
      "type": "string",
      "description": "商标状态：待审核/已审核/已拒绝",
      "enum": ["pending-review", "reviewed", "rejected"]
    },
    "reviewStatus": {
      "type": "string",
      "description": "审核状态：待审核/已通过/已拒绝",
      "enum": ["pending", "approved", "rejected"]
    },
    "aiGenerated": {
      "type": "boolean",
      "description": "是否由AI生成（标记数据来源，便于后续人工复核）"
    },
    "metadata": {
      "type": "object",
      "description": "可选的扩展元数据，用于存储未在Schema中明确定义的额外信息",
      "additionalProperties": true
    },
    "_meta": {
      "type": "object",
      "description": "溯源元数据块，记录该条数据的来源、Schema版本和置信度",
      "required": ["source", "schema_version", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "派生来源，如 'manual'、'ai-generated'、'official-api'"
        },
        "schema_version": {
          "type": "string",
          "description": "Schema版本号，遵循 semver，如 '1.0.0'"
        },
        "unverified_fields": {
          "type": "array",
          "description": "尚未经人工核实的字段名列表",
          "items": {"type": "string"}
        },
        "confidence": {
          "type": "string",
          "description": "数据置信度",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}

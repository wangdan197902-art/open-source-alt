{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ossaf.local/schemas/comparison.schema.json",
  "title": "Comparison",
  "description": "商业软件与开源软件对比内容的单一真相源 (SSOT)，供 Mock 数据生成器、Hugo 内容生成器和适配器共用。",
  "type": "object",
  "required": [
    "id",
    "proprietaryId",
    "openSourceId",
    "featureComparison",
    "pros",
    "cons",
    "migrationDifficulty",
    "useCases",
    "aiGenerated",
    "reviewStatus",
    "_meta"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，使用 kebab-case，如 'photoshop-vs-gimp'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 128
    },
    "proprietaryId": {
      "type": "string",
      "description": "关联的商业软件ID，对应 proprietary.schema.json 的 id 字段",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "openSourceId": {
      "type": "string",
      "description": "关联的开源软件ID，对应 opensource.schema.json 的 id 字段",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "featureComparison": {
      "type": "array",
      "description": "功能逐项对比列表",
      "items": {
        "type": "object",
        "description": "单个功能的对比条目",
        "required": ["feature", "proprietarySupport", "openSourceSupport"],
        "additionalProperties": false,
        "properties": {
          "feature": {
            "type": "string",
            "description": "功能名称，如 '图层编辑'、'CMYK色彩模式'",
            "minLength": 1,
            "maxLength": 128
          },
          "proprietarySupport": {
            "type": "string",
            "description": "商业软件对该功能的支持程度：支持/部分支持/不支持",
            "enum": ["yes", "partial", "no"]
          },
          "openSourceSupport": {
            "type": "string",
            "description": "开源软件对该功能的支持程度：支持/部分支持/不支持",
            "enum": ["yes", "partial", "no"]
          },
          "notes": {
            "type": "string",
            "description": "可选的功能差异备注",
            "maxLength": 512
          }
        }
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "pros": {
      "type": "array",
      "description": "开源软件相对于商业软件的优势列表",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "cons": {
      "type": "array",
      "description": "开源软件相对于商业软件的劣势列表",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "migrationDifficulty": {
      "type": "string",
      "description": "迁移难度等级：简单/中等/困难",
      "enum": ["easy", "medium", "hard"]
    },
    "useCases": {
      "type": "array",
      "description": "适用场景列表，如 ['个人用户', '教育用途']",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "aiGenerated": {
      "type": "boolean",
      "description": "是否由AI生成（标记数据来源，便于后续人工复核）"
    },
    "aiGeneratedDetails": {
      "type": "object",
      "description": "AI生成的详情，包括使用的模型、生成时间等",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": "string",
          "description": "生成内容所用的AI模型标识，如 'gpt-4-turbo'、'claude-3-opus'",
          "maxLength": 64
        },
        "generatedAt": {
          "type": "string",
          "description": "生成时间，ISO 8601 格式，如 '2024-01-15T08:30:00Z'",
          "format": "date-time"
        },
        "promptHash": {
          "type": "string",
          "description": "所用提示词的哈希值（用于追溯与去重）",
          "maxLength": 128
        },
        "tokensUsed": {
          "type": "integer",
          "description": "本次生成消耗的 token 数量",
          "minimum": 0
        }
      }
    },
    "reviewStatus": {
      "type": "string",
      "description": "审核状态：待审核/已通过/已拒绝",
      "enum": ["pending", "approved", "rejected"]
    },
    "metadata": {
      "type": "object",
      "description": "可选的扩展元数据，用于存储未在Schema中明确定义的额外信息",
      "additionalProperties": true
    },
    "_meta": {
      "type": "object",
      "description": "溯源元数据块，记录该条数据的来源、Schema版本和置信度",
      "required": ["source", "schema_version", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "派生来源，如 'manual'、'ai-generated'、'official-api'"
        },
        "schema_version": {
          "type": "string",
          "description": "Schema版本号，遵循 semver，如 '1.0.0'"
        },
        "unverified_fields": {
          "type": "array",
          "description": "尚未经人工核实的字段名列表",
          "items": {"type": "string"}
        },
        "confidence": {
          "type": "string",
          "description": "数据置信度",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}

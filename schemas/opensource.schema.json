{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ossaf.local/schemas/opensource.schema.json",
  "title": "Open Source Software",
  "description": "开源软件记录的单一真相源 (SSOT)，供 Mock 数据生成器、Hugo 内容生成器和适配器共用。",
  "type": "object",
  "required": [
    "id",
    "name",
    "license",
    "repository",
    "category",
    "platforms",
    "maturityLevel",
    "communitySize",
    "reviewStatus",
    "aiGenerated",
    "_meta"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，使用 kebab-case，如 'gimp'、'libreoffice'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "name": {
      "type": "string",
      "description": "开源软件官方名称，如 'GIMP'、'LibreOffice'",
      "minLength": 1,
      "maxLength": 128
    },
    "license": {
      "type": "string",
      "description": "OSI 认证的开源协议 SPDX 标识符",
      "enum": [
        "MIT",
        "Apache-2.0",
        "GPL-2.0",
        "GPL-3.0",
        "BSD-2-Clause",
        "BSD-3-Clause",
        "LGPL-2.1",
        "LGPL-3.0",
        "MPL-2.0",
        "AGPL-3.0",
        "CDDL-1.0",
        "EPL-2.0"
      ]
    },
    "repository": {
      "type": "string",
      "description": "代码仓库URL，通常为 Git 托管平台地址",
      "format": "uri",
      "pattern": "^https?://"
    },
    "category": {
      "type": "string",
      "description": "分类标识符，使用 kebab-case，如 'image-editing'、'office-suite'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 64
    },
    "platforms": {
      "type": "array",
      "description": "支持的平台列表，如 ['windows', 'macos', 'linux']",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 32
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "maturityLevel": {
      "type": "string",
      "description": "项目成熟度等级：实验性/测试版/稳定版/成熟",
      "enum": ["experimental", "beta", "stable", "mature"]
    },
    "communitySize": {
      "type": "string",
      "description": "社区规模：小型/中型/大型/超大",
      "enum": ["small", "medium", "large", "huge"]
    },
    "reviewStatus": {
      "type": "string",
      "description": "审核状态：待审核/已通过/已拒绝",
      "enum": ["pending", "approved", "rejected"]
    },
    "aiGenerated": {
      "type": "boolean",
      "description": "是否由AI生成（标记数据来源，便于后续人工复核）"
    },
    "metadata": {
      "type": "object",
      "description": "可选的扩展元数据，用于存储未在Schema中明确定义的额外信息",
      "additionalProperties": true
    },
    "_meta": {
      "type": "object",
      "description": "溯源元数据块，记录该条数据的来源、Schema版本和置信度",
      "required": ["source", "schema_version", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "派生来源，如 'manual'、'ai-generated'、'official-api'"
        },
        "schema_version": {
          "type": "string",
          "description": "Schema版本号，遵循 semver，如 '1.0.0'"
        },
        "unverified_fields": {
          "type": "array",
          "description": "尚未经人工核实的字段名列表",
          "items": {"type": "string"}
        },
        "confidence": {
          "type": "string",
          "description": "数据置信度",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}

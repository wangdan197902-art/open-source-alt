{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ossaf.local/schemas/image-meta.schema.json",
  "title": "Image Metadata",
  "description": "配图元数据的单一真相源 (SSOT)，记录图片生成信息、许可证与审核状态，供 Mock 数据生成器、Hugo 内容生成器和适配器共用。",
  "type": "object",
  "required": [
    "id",
    "type",
    "prompt",
    "modelUsed",
    "url",
    "altText",
    "licenseInfo",
    "reviewStatus",
    "_meta"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，使用 kebab-case，如 'gimp-screenshot-main'",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 128
    },
    "type": {
      "type": "string",
      "description": "图片类型：截图/Logo/示意图/对比图/图标/插画",
      "enum": ["screenshot", "logo", "diagram", "comparison-chart", "icon", "illustration"]
    },
    "prompt": {
      "type": "string",
      "description": "图片生成提示词（如使用 AI 生成时记录的提示词文本）",
      "minLength": 1,
      "maxLength": 2048
    },
    "modelUsed": {
      "type": "string",
      "description": "用于生成图片的模型标识，如 'dall-e-3'、'stable-diffusion-xl'、'midjourney-v6'",
      "minLength": 1,
      "maxLength": 64
    },
    "url": {
      "type": "string",
      "description": "图片访问URL（可为本地相对路径或CDN URL）",
      "format": "uri",
      "minLength": 1,
      "maxLength": 1024
    },
    "altText": {
      "type": "string",
      "description": "图片替代文本（用于无障碍访问和SEO），建议简洁描述图片内容",
      "minLength": 1,
      "maxLength": 256
    },
    "licenseInfo": {
      "type": "string",
      "description": "图片许可证信息，如 'CC BY 4.0'、'Public Domain'、'Proprietary - Adobe'",
      "minLength": 1,
      "maxLength": 128
    },
    "reviewStatus": {
      "type": "string",
      "description": "审核状态：待审核/已通过/已拒绝",
      "enum": ["pending", "approved", "rejected"]
    },
    "metadata": {
      "type": "object",
      "description": "可选的扩展元数据，用于存储未在Schema中明确定义的额外信息（如宽高、文件大小、生成参数等）",
      "additionalProperties": true
    },
    "_meta": {
      "type": "object",
      "description": "溯源元数据块，记录该条数据的来源、Schema版本和置信度",
      "required": ["source", "schema_version", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "派生来源，如 'manual'、'ai-generated'、'official-api'"
        },
        "schema_version": {
          "type": "string",
          "description": "Schema版本号，遵循 semver，如 '1.0.0'"
        },
        "unverified_fields": {
          "type": "array",
          "description": "尚未经人工核实的字段名列表",
          "items": {"type": "string"}
        },
        "confidence": {
          "type": "string",
          "description": "数据置信度",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  }
}
